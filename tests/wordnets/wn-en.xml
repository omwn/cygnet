    <Provenance resource="wn-en" version="1.0"/>
  </ConceptRelation>

  <!-- Adjective relations: gleaming and glowing are variants of bright -->
  <!-- eq_synonym fallback: gleaming (i7) ≈ bright (i6, has ARASAAC) — ADJ ↔ ADJ -->
  <ConceptRelation relation_type="eq_synonym" source="cili.i7" target="cili.i6">
    <Provenance resource="wn-en" version="1.0"/>
  </ConceptRelation>
  <!-- similar fallback: glowing (i8) ~ bright (i6, has ARASAAC) — ADJ ↔ ADJ -->
  <ConceptRelation relation_type="similar" source="cili.i8" target="cili.i6">
    <Provenance resource="wn-en" version="1.0"/>
