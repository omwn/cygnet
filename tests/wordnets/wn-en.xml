<?xml version='1.0' encoding='UTF-8'?>
<!--
  Test English wordnet.  Concepts here serve as the shared ILI layer;
  other test wordnets (wn-fr.xml etc.) reference ILIs declared here.

  Concepts and relations mirror OEWN structure (simplified):

  Noun hierarchy:
    entity (i1) ← animal (i2) ← dog (i3)
    brightness (i4)  — standalone quality noun
    dogfish (i5)     — standalone noun (enables "dog*" glob test)

  Adjective cluster:
    bright (i6)   — canonical luminosity adjective; has ARASAAC pictogram
    gleaming (i7) — eq_synonym of bright; no direct pictogram (fallback test)
    glowing (i8)  — similar to bright; no direct pictogram (fallback test)

  Sense relations:
    gleaming antonym glowing   — tests sense-level relation display

  Note: ILI IDs (i1–i8) are test fixtures; i3 is referenced by wn-fr.xml
  and wn-bad.xml, so those three must not be renumbered.
-->
<CygnetResource id="wn-en" label="Test English WordNet" language="en" version="1.0" citation="Bond, F. 2025. `Test WordNet &lt;https://github.com/rowanhm/cygnet&gt;`_. In *Proceedings of a Test Conference*.">

  <!-- Concepts (ILI declarations shared by all wordnets) -->
  <Concept id="cili.i1" ontological_category="NOUN" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-entity-n"/>
  </Concept>
  <Concept id="cili.i2" ontological_category="NOUN" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-animal-n"/>
  </Concept>
  <Concept id="cili.i3" ontological_category="NOUN" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-dog-n"/>
  </Concept>
  <Concept id="cili.i4" ontological_category="NOUN" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-brightness-n"/>
  </Concept>
  <Concept id="cili.i5" ontological_category="NOUN" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-dogfish-n"/>
  </Concept>
  <Concept id="cili.i6" ontological_category="ADJ" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-bright-a"/>
  </Concept>
  <Concept id="cili.i7" ontological_category="ADJ" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-gleaming-a"/>
  </Concept>
  <Concept id="cili.i8" ontological_category="ADJ" status="1">
    <Provenance resource="wn-en" version="1.0" original_id="oewn-glowing-a"/>
  </Concept>

  <!-- English definitions (from OEWN / Princeton WordNet) -->
  <Gloss definiendum="cili.i1" language="en">
    <AnnotatedSentence>that which is perceived or known or inferred to have its own distinct existence (living or nonliving)</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i2" language="en">
    <AnnotatedSentence>a living animal; any member of the kingdom Animalia</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i3" language="en">
    <AnnotatedSentence>a domesticated carnivorous animal (Canis lupus familiaris), the most widely kept companion animal</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i4" language="en">
    <AnnotatedSentence>the quality of being bright</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i5" language="en">
    <AnnotatedSentence>any of several small sharks with a long pointed snout</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i6" language="en">
    <AnnotatedSentence>emitting or reflecting light readily or in large amounts</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i7" language="en">
    <AnnotatedSentence>bright with a steady but subdued sheen</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>
  <Gloss definiendum="cili.i8" language="en">
    <AnnotatedSentence>emitting or reflecting light steadily and softly</AnnotatedSentence>
    <Provenance resource="wn-en" version="1.0"/>
  </Gloss>

